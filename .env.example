# Copy to .env and fill in real values for production.

# CORS — comma-separated origins (Vite default: http://localhost:5173)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Twilio SMS (dummy values = simulation mode only)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# SMTP email — Gmail example (dummy values = simulation mode only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USE_TLS=false
SMTP_USER=your_gmail_address@example.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM_EMAIL=your_gmail_from_address@example.com

# Optional: when set, simulated buyer emails are "sent" here in dry-run logs
BUYER_NOTIFICATION_EMAIL=buyer_notifications@example.com
